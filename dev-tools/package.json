{
  "name": "@eco-incorp/sauce-dev-tools",
  "version": "0.0.1",
  "private": true,
  "description": "Development tools for the Sauce protocol",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eco-incorp/sauce-sdk.git",
    "directory": "dev-tools"
  },
  "homepage": "https://github.com/eco-incorp/sauce-sdk#readme",
  "bugs": "https://github.com/eco-incorp/sauce-sdk/issues",
  "bin": {
    "sauce-dev-tools": "scripts/init.js"
  },
  "files": [
    "scripts",
    "src",
    "sauce",
    "artifacts",
    "hardhat.config.cjs",
    "tsconfig.json",
    "README.md",
    "COMPILER.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "cp ../compiler/README.md COMPILER.md",
    "sauce": "npx tsx scripts/run.ts",
    "start:local": "./scripts/start-local.sh",
    "start:fork": "./scripts/start-fork.sh",
    "stop": "./scripts/stop-local.sh",
    "sync-price": "npx tsx scripts/sync-price.ts",
    "sync-artifacts": "node scripts/sync-artifacts.js",
    "test": "npx tsx test/examples.test.ts && npx tsx test/runner.test.ts",
    "test:e2e": "npx tsx test/e2e.test.ts",
    "format": "npx prettier --write sauce scripts test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "hardhat": "^2.22.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@eco-incorp/sauce-compiler": "workspace:*",
    "@uniswap/v3-core": "^1.0.1",
    "dotenv": "^17.3.1",
    "viem": "^2.45.1"
  }
}
