ss\",\"name\":\"v12Runtime_\",\"type\":\"address\"},{\"internalType\":\"address\",\"name\":\"router_\",\"type\":\"address\"}],\"stateMutability\":\"nonpayable\",\"type\":\"constructor\"},{\"inputs\":[],\"name\":\"ZeroOwner\",\"type\":\"error\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"address\",\"name\":\"owner\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"salt\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"address\",\"name\":\"pot\",\"type\":\"address\"}],\"name\":\"PotDeployed\",\"type\":\"event\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"owner\",\"type\":\"address\"},{\"internalType\":\"bytes32\",\"name\":\"salt\",\"type\":\"bytes32\"}],\"name\":\"deployPot\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"pot\",\"type\":\"address\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"owner\",\"type\":\"address\"},{\"internalType\":\"bytes32\",\"name\":\"salt\",\"type\":\"bytes32\"}],\"name\":\"predictPot\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"router\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"v12Runtime\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"The v12 counterpart of {Kitchen}. Each V12Pot is deployed via CREATE2 keyed on (owner, salt),      with the owner baked into the Pot's constructor args \\u2014 so the address commits to its owner and      no separate registry is needed. Unlike {Kitchen}, a V12Pot needs TWO implementations: the v12      Huff runtime ({V12Pot.cook} delegatecalls it) and the v1 swap Router ({V12Pot.fallback}      delegatecalls it). Both are baked into every deployed Pot. The Kitchen only *deploys* Pots; it      never cooks on a user's behalf, so the steady-state flow is: deploy your Pot once, then call      it directly.\",\"kind\":\"dev\",\"methods\":{\"deployPot(address,bytes32)\":{\"params\":{\"owner\":\"The Pot's owner (baked into its CREATE2 address; only address that can cook).\",\"salt\":\"Caller-chosen salt allowing multiple Pots per owner.\"},\"returns\":{\"pot\":\"The deployed (or pre-existing) V12Pot address.\"}}},\"title\":\"V12Kitchen\",\"version\":1},\"userdoc\":{\"errors\":{\"ZeroOwner()\":[{\"notice\":\"Thrown when a Pot deployment is requested for the zero address. Such a Pot could         never `cook()` (the zero address can't sign), so funds sent to it would be locked.\"}]},\"kind\":\"user\",\"methods\":{\"deployPot(address,bytes32)\":{\"notice\":\"Deploy a V12Pot for `owner` at the given salt, or return it if already deployed.\"},\"predictPot(address,bytes32)\":{\"notice\":\"Predict the V12Pot address for a given owner and salt.\"},\"router()\":{\"notice\":\"The v1 {Router} DEX swap implementation every Pot's {V12Pot.fallback} delegates into.\"},\"v12Runtime()\":{\"notice\":\"The v12 Huff runtime every Pot's {V12Pot.cook} delegates into.\"}},\"notice\":\"Factory / entry point that deterministically deploys per-user {V12Pot} proxies.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/V12Kitchen.sol\":\"V12Kitchen\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":1000},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":forge-std/=lib/forge-std/src/\",\":foundry-huff-neo/=lib/foundry-huff-neo/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"lib/openzeppelin-contracts/contracts/utils/Create2.sol\":{\"keccak256\":\"0xe06ddfff69f3ba154d92102d9a85db2780e045303a587360cf12195216e851ca\",\"license\":\"MIT\",\"urls\":[\"