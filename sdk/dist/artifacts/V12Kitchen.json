\"},\"returns\":{\"pot\":\"The deployed (or pre-existing) V12Pot address.\"}}},\"title\":\"V12Kitchen\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"deployPot(bytes32)\":{\"notice\":\"Deploy the caller's V12Pot for the given salt, or return it if already deployed.\"},\"predictPot(address,bytes32)\":{\"notice\":\"Predict the V12Pot address for a given owner and salt.\"},\"router()\":{\"notice\":\"The v1 SauceRouter swap implementation every Pot's {V12Pot.fallback} delegates into.\"},\"v12Runtime()\":{\"notice\":\"The v12 Huff runtime every Pot's {V12Pot.cook} delegates into.\"}},\"notice\":\"Factory / entry point that deterministically deploys per-user {V12Pot} proxies.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/V12Kitchen.sol\":\"V12Kitchen\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":1000},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":forge-std/=lib/forge-std/src/\",\":foundry-huff-neo/=lib/foundry-huff-neo/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"],\"viaIR\":true},\"sources\":{\"lib/openzeppelin-contracts/contracts/utils/Create2.sol\":{\"keccak256\":\"0xe06ddfff69f3ba154d92102d9a85db2780e045303a587360cf12195216e851ca\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://ac19cc390a227758c239c06d3a11d0a2c40c8f58eabb034154b661269d4a0851\",\"dweb:/ipfs/QmdSsfYsPX5RyAXSfHRvR5zdY9MffAgZVa3vdxQUypFBa5\"]},\"lib/openzeppelin-contracts/contracts/utils/Errors.sol\":{\"keccak256\":\"0x6afa713bfd42cf0f7656efa91201007ac465e42049d7de1d50753a373648c123\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://ba1d02f4847670a1b83dec9f7d37f0b0418d6043447b69f3a29a5f9efc547fcf\",\"dweb:/ipfs/QmQ7iH2keLNUKgq2xSWcRmuBE5eZ3F5whYAkAGzCNNoEWB\"]},\"lib/openzeppelin-contracts/contracts/utils/LowLevelCall.sol\":{\"keccak256\":\"0x48939a28e8337bdb215bf7146eef5b9e71c7385c49e30a07f9e6b96465d09f61\",\"license\":\"MIT\",\"urls\":[\"bzz-raw:/