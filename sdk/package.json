{
  "name": "@eco-incorp/sauce-sdk-source",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eco-incorp/sauce-sdk.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/eco-incorp/sauce-sdk#readme",
  "bugs": "https://github.com/eco-incorp/sauce-sdk/issues",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./protocols/*": {
      "types": "./dist/protocols/*/index.d.ts",
      "default": "./dist/protocols/*/index.js"
    },
    "./chains": {
      "types": "./dist/chains/index.d.ts",
      "default": "./dist/chains/index.js"
    },
    "./skills": {
      "types": "./dist/skills/loader.d.ts",
      "default": "./dist/skills/loader.js"
    },
    "./recipes": {
      "types": "./dist/recipes/index.d.ts",
      "default": "./dist/recipes/index.js"
    }
  },
  "files": [
    "dist",
    "src/skills",
    "src/protocols",
    "src/recipes",
    "src/artifacts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-recipe-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.cjs",
    "test:recipes": "tsx --test src/recipes/test/compile.test.ts src/recipes/test/ecoswap.compile.test.ts src/recipes/test/ecoswap.math.test.ts src/recipes/test/ecoswap.optimal.test.ts src/recipes/test/ecoswap.solver-reference.test.ts src/recipes/test/ecoswap.algebra.test.ts src/recipes/test/ecoswap.lb.test.ts src/recipes/test/ecoswap.dodo.test.ts src/recipes/test/ecoswap.band-window.test.ts src/recipes/test/chain-pool-configs.test.ts",
    "test:recipes:evm": "bash src/recipes/test/fixtures/build.sh && tsx --test --test-concurrency=1 src/recipes/test/*.evm.test.ts"
  },
  "dependencies": {
    "@eco-incorp/sauce-compiler": "workspace:*",
    "viem": "^2.45.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "tsx": "^4.7.0",
    "@uniswap/v3-core": "^1.0.1",
    "@pancakeswap/v3-core": "^1.0.2"
  }
}
